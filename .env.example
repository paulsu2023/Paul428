# Local demo mode skips Supabase auth, database writes, and Stripe billing.
NEXT_PUBLIC_DEMO_MODE=true

# Public app URL used by auth and Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Gemini / Google AI Studio
# GOOGLE_API_KEY is preferred; GEMINI_API_KEY is also supported by the app.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_BASE_URL=

# FlowAPI / flow2api-compatible service.
# This project expects an OpenAI-compatible /v1/chat/completions endpoint.
FLOW_API_BASE_URL=http://127.0.0.1:38000
FLOW_API_KEY=han1234

# Supabase is optional in demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe is optional in demo mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
